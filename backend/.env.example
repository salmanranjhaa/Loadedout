APP_NAME=LoadedOut
DEBUG=false

# Database (Cloud SQL)
DATABASE_URL=postgresql+asyncpg://LoadedOut_user:YOUR_PASSWORD@/LoadedOut_db?host=/cloudsql/YOUR_PROJECT:europe-west6:LoadedOut-db
DATABASE_URL_SYNC=postgresql+psycopg2://LoadedOut_user:YOUR_PASSWORD@/LoadedOut_db?host=/cloudsql/YOUR_PROJECT:europe-west6:LoadedOut-db

# For local dev
# DATABASE_URL=postgresql+asyncpg://LoadedOut_user:changeme@localhost:5432/LoadedOut_db
# DATABASE_URL_SYNC=postgresql+psycopg2://LoadedOut_user:changeme@localhost:5432/LoadedOut_db

# Auth
SECRET_KEY=generate-a-long-random-string-here

# Google Cloud
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west6
VERTEX_AI_MODEL=gemini-1.5-flash
EMBEDDING_MODEL=text-embedding-004
