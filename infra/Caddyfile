(routes) {
    handle /health {
        reverse_proxy backend:8000
    }
    handle /api/* {
        reverse_proxy backend:8000
    }
    handle /mcp/* {
        reverse_proxy mcp:8003 {
            flush_interval -1
        }
    }
    handle {
        root * /usr/share/caddy
        try_files {path} /index.html

        # Hashed assets are immutable; everything that controls updates
        # (index.html, sw.js, manifest) must always revalidate so installed
        # PWAs pick up new releases immediately.
        @immutable path /assets/*
        header @immutable Cache-Control "public, max-age=31536000, immutable"
        @no_cache path / /index.html /sw.js /registerSW.js /manifest.webmanifest /manifest.json
        header @no_cache Cache-Control "no-cache, must-revalidate"
        @icons path /favicon.ico /favicon-*.png /icon-*.png /apple-touch-icon.png
        header @icons Cache-Control "public, max-age=86400"
        @apk path *.apk
        header @apk Content-Disposition "attachment"
        header @apk Cache-Control "no-cache"

        file_server
    }
}

loadedout.online {
    import routes
}

www.loadedout.online {
    redir https://loadedout.online{uri} permanent
}

salmanranjha.me {
    redir https://www.salmanranjha.me{uri} permanent
}

www.salmanranjha.me {
    reverse_proxy portfolio-web:80
}

http://salmanranjha.me {
    redir https://www.salmanranjha.me{uri} permanent
}

polarisedu.info {
    reverse_proxy polaris-backend:3001
}

www.polarisedu.info {
    redir https://polarisedu.info{uri} 301
}

# ERP-RAG — no owned domain, so use sslip.io wildcard DNS (hostname -> 34.17.37.87)
# which lets Caddy obtain real Let's Encrypt certs without buying DNS.
erp-rag.34.17.37.87.sslip.io {
    reverse_proxy erp-rag-app:8000 {
        flush_interval -1
    }
}

strata.34.17.37.87.sslip.io {
    reverse_proxy erp-openclaw:8001 {
        flush_interval -1
    }
}

# HBU Teaching Assistant — no owned domain, so use the sslip.io wildcard (-> 34.17.37.87).
# hbu-web is the project's own Caddy that serves the SPA and proxies /api to hbu-backend.
# flush_interval -1 keeps the chat SSE stream flowing token by token.
hbu.34.17.37.87.sslip.io {
    reverse_proxy hbu-web:80 {
        flush_interval -1
    }
}
